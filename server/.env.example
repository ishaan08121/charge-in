# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from: https://app.supabase.com → Settings → API
SUPABASE_URL=

# Service Role key (never expose to frontend) — Settings → API → service_role
SUPABASE_SERVICE_KEY=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# From: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Razorpay X (Payouts) ─────────────────────────────────────────────────────
# Current account number from Razorpay X dashboard
RAZORPAYX_ACCOUNT_NUMBER=

# ─── Expo Push Notifications ──────────────────────────────────────────────────
# Optional: Expo access token for enhanced push delivery
# From: https://expo.dev → Account → Access Tokens
EXPO_ACCESS_TOKEN=
